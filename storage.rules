rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos: only the owner can write, any authenticated user can read
    match /profile_photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches(request.auth.uid + '_.*');
    }

    // Default: deny all other paths unless scoped rules are added
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
